{
  "name": "reprompt",
  "version": "1.0.0",
  "description": "Global AI Text Optimizer - Background Windows app using Anthropic API (Claude 3.5 Sonnet)",
  "main": "dist/main/main.js",
  "author": "RePrompt",
  "license": "MIT",
  "scripts": {
    "copy-static": "xcopy /Y /I src\\renderer\\*.html dist\\renderer\\ && xcopy /Y /I src\\renderer\\*.css dist\\renderer\\",
    "dev": "tsc && npm run copy-static && electron .",
    "build": "tsc && npm run copy-static",
    "package": "npm run build && electron-builder --win",
    "start": "electron ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "auto-launch": "^5.0.6",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@types/auto-launch": "^5.0.5",
    "@types/node": "^20.10.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "typescript": "^5.9.3"
  },
  "build": {
    "extends": "electron-builder.yml",
    "publish": [
      {
        "provider": "generic",
        "url": "https://reprompt-one.vercel.app/download"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icons/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowElevation": true,
      "deleteAppDataOnUninstall": true,
      "include": "resources/installer.nsh",
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    }
  }
}